# Base path the SPA prepends to every API call (handled by the Vite dev proxy below)
VITE_API_BASE_URL=/api/v1

# Where the Vite dev server proxies /api during `npm run dev`
VITE_API_PROXY_TARGET=http://localhost:8090

# When true, every feature module (Pharmacy, Pub/Restaurant) is shown in the
# sidebar regardless of the company's business type. Leave false in production
# to load modules by business type as described in the README.
VITE_SHOW_ALL_MODULES=false
